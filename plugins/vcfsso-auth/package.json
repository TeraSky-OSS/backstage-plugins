    "prepack": "backstage-cli package prepack",
    "postpack": "backstage-cli package postpack"
  },
  "dependencies": {
    "@backstage/core-app-api": "^1.19.5",
    "@backstage/core-plugin-api": "^1.12.3",
    "@backstage/frontend-plugin-api": "^0.14.1"
  },
  "devDependencies": {
    "@backstage/cli": "^0.35.4"
  },
  "files": [
    "dist"
  ]
